# Admin login for /admin (upload, caption, reorder, delete photos).
# Copy to your Vercel project's Environment Variables — never commit real values.

# Password for the /admin login form. Required.
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: secret used to sign the admin session cookie. If unset,
# ADMIN_PASSWORD is used instead. Set this if you want sessions to stay
# valid even after changing ADMIN_PASSWORD.
SESSION_SECRET=

# Vercel Blob storage token. Auto-populated when you connect a Blob store
# to this project in the Vercel dashboard (Storage tab) — you usually
# don't need to set this manually.
BLOB_READ_WRITE_TOKEN=
