# Instagram Graph API credentials (from developers.facebook.com).
# Copy to your Vercel project's Environment Variables — never commit real values.

IG_APP_ID=your-instagram-app-id
IG_APP_SECRET=your-instagram-app-secret
IG_REDIRECT_URI=https://your-domain.vercel.app/api/auth/callback

# Paste the long-lived token printed by /api/auth/callback after connecting once.
IG_LONG_LIVED_TOKEN=

# Optional: protects /api/sync from being triggered by strangers.
SYNC_SECRET=change-me-to-a-random-string
